lemma hn_Var[sepref_fr_rules]:
  "hn_refine (hn_ctxt V a a') (return (Var a')) (hn_invalid V a a') (term_assn F V) (RETURN$((Var) $a))"
  unfolding hn_refine_def
  sorry

lemma hn_Fun[sepref_fr_rules]:
  "hn_refine 
  (hn_ctxt F f f' * hn_ctxt (list_assn (term_assn F V)) ts ts')
  (return (Fun f' ts'))
  (hn_invalid F f f' * hn_ctxt (list_assn (term_assn F V)) ts ts')
  (term_assn F V)
  (RETURN$((Fun) $f$ts))"
  unfolding hn_refine_def
  sorry


lemma pure_conj_eq: "\<up>P * \<up>Q = \<up>(P \<and> Q)"
  by (simp add: pure_def)


lemma term_list_assn_pure_conv : 
  "term_list_assn (pure F) (pure V) fas fis = 
   pure (\<langle>term_rel F V\<rangle>list_rel) fas fis"
  unfolding pure_def list_rel_def term_rel_def
  apply simp
  sorry

lemma term_assn_pure_conv[constraint_simps]: 
"term_assn (pure F) (pure V) = pure (term_rel F V)"
proof (intro ext)                                 
  fix t ti
  show "term_assn (pure F) (pure V) t ti = pure (term_rel F V) t ti"
    unfolding term_rel_def  pure_def relAPP_def list_rel_def
    apply (cases t; cases ti; simp_all)
    subgoal for fa fas fi fis
      sorry
    done
qed

lemma term_assn_pure[constraint_simps] : 
  assumes F:"is_pure F"
  assumes V:"is_pure V"
  shows "is_pure (term_assn F V)"
  sorry

