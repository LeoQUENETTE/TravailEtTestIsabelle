fun term_relp :: 
  "('fa \<Rightarrow> 'fc \<Rightarrow> bool) \<Rightarrow> ('va \<Rightarrow> 'vc \<Rightarrow> bool) \<Rightarrow> 
   ('fa,'va) term \<Rightarrow> ('fc,'vc) term \<Rightarrow> bool"
and term_list_relp ::
  "('fa \<Rightarrow> 'fc \<Rightarrow> bool) \<Rightarrow> ('va \<Rightarrow> 'vc \<Rightarrow> bool) \<Rightarrow>
   ('fa,'va) term list \<Rightarrow> ('fc,'vc) term list \<Rightarrow> bool"
where
  "term_relp F V (Var v)     (Var v')      \<longleftrightarrow> V v v'"
| "term_relp F V (Fun f ts) (Fun f' ts')  \<longleftrightarrow> F f f' \<and> term_list_relp F V ts ts'"
| "term_relp F V _           _             \<longleftrightarrow> False"
| "term_list_relp F V []      []           \<longleftrightarrow> True"
| "term_list_relp F V (t#ts) (t'#ts')     \<longleftrightarrow> term_relp F V t t' \<and> term_list_relp F V ts ts'"
| "term_list_relp F V _       _            \<longleftrightarrow> False"

definition term_rel :: 
  "('fa \<times> 'fc) set \<Rightarrow> ('va \<times> 'vc) set \<Rightarrow> 
   (('fa,'va) term \<times> ('fc,'vc) term) set"
where
  "term_rel F V \<equiv> {(t, t'). term_relp (\<lambda>x y. (x,y) \<in> F) (\<lambda>x y. (x,y) \<in> V) t t'}"

fun term_assn :: 
  "('fa \<Rightarrow> 'fc \<Rightarrow> assn) \<Rightarrow> ('va \<Rightarrow> 'vc \<Rightarrow> assn) \<Rightarrow> ('fa, 'va) term \<Rightarrow> ('fc, 'vc) term \<Rightarrow> assn" 
and term_list_assn ::                                           
  "('fa \<Rightarrow> 'fc \<Rightarrow> assn) \<Rightarrow> ('va \<Rightarrow> 'vc \<Rightarrow> assn) \<Rightarrow> ('fa, 'va) term list \<Rightarrow> ('fc, 'vc) term list \<Rightarrow> assn"
where
  "term_assn F V (Var x) (Var y) = V x y"
| "term_assn F V (Fun f ts) (Fun g us) = F f g * term_list_assn F V ts us"
| "term_assn F V _ _ = false"
| "term_list_assn F V [] [] = emp"
| "term_list_assn F V (t#ts) (u#us) = term_assn F V t u * term_list_assn F V ts us"
| "term_list_assn F V _ _ = false"
print_theorems             
